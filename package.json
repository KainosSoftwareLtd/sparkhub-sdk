{
  "name": "sparkhub-sdk-monorepo",
  "private": true,
  "description": "Workspaces root for @sparkhub/sdk + @sparkhub/react. The published packages live under packages/.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "type-check": "npm run type-check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KainosSoftwareLtd/sparkhub-sdk.git"
  },
  "engines": {
    "node": ">=18"
  }
}
