{
  "name": "@sparkhub/sdk",
  "version": "0.1.0",
  "description": "OAuth client library for browser-based partner apps on the SparkHub platform.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "sparkhub",
    "oauth",
    "pkce",
    "partner-app",
    "browser-sdk"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KainosSoftwareLtd/sparkhub-sdk.git"
  },
  "homepage": "https://github.com/KainosSoftwareLtd/sparkhub-sdk#readme",
  "bugs": {
    "url": "https://github.com/KainosSoftwareLtd/sparkhub-sdk/issues"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
