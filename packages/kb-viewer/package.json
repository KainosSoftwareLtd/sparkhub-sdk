{
  "name": "@sparkhub/kb-viewer",
  "version": "0.5.0",
  "description": "Read-only BlockNote viewer for SparkHub Knowledge Base content \u2014 renders the `content` block array served by SparkHub's public KB API.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "sparkhub",
    "blocknote",
    "knowledge-base",
    "viewer",
    "partner-app"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/KainosSoftwareLtd/sparkhub-sdk.git",
    "directory": "packages/kb-viewer"
  },
  "homepage": "https://github.com/KainosSoftwareLtd/sparkhub-sdk/tree/main/packages/kb-viewer#readme",
  "bugs": {
    "url": "https://github.com/KainosSoftwareLtd/sparkhub-sdk/issues"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@blocknote/core": "^0.31.0",
    "@blocknote/mantine": "^0.31.0",
    "@blocknote/react": "^0.31.0",
    "dompurify": "^3.2.0",
    "mermaid": "^11.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
