# SparkHub partner-app — sample env config (Vite + React example).
# Copy to `.env.local` for local dev. `VITE_*` vars are exposed to the client
# bundle by Vite — do NOT put secrets here.

# Required: client ID from your registered partner app
# (https://sparkhub.studio/security-admin/partner-apps -> Register app -> copy papp_...)
VITE_SPARKHUB_CLIENT_ID=papp_REPLACE_WITH_YOURS

# Optional: SparkHub host. Defaults to https://sparkhub.studio.
# For local-dev SparkHub: http://<orgcode>.localhost:3000
VITE_SPARKHUB_BASE=https://sparkhub.studio

# Optional: org-code hint. REQUIRED when using a localhost-style redirect URI
# (no org subdomain in the URL). Production deployments at
# {org}.{ns}.sparkhub.run can omit this — SparkHub reads org from the host.
# VITE_SPARKHUB_ORG=beatles

# Optional: comma-separated scopes. Defaults to "partner-app:read".
# VITE_SPARKHUB_SCOPES=partner-app:read,partner-app:trigger-process
